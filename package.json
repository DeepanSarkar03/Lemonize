{
  "name": "lemonize",
  "version": "0.1.0",
  "private": true,
  "description": "Lemonize \u2014 a developer package distribution platform with a Cloudflare-powered global CDN.",
  "license": "MIT",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:worker": "pnpm --filter @lemonize/registry-worker dev",
    "dev:npm-proxy": "pnpm --filter @lemonize/npm-proxy-worker dev",
    "dev:web": "pnpm --filter @lemonize/web dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "deploy:worker": "pnpm --filter @lemonize/registry-worker deploy",
    "deploy:npm-proxy:staging": "pnpm --filter @lemonize/npm-proxy-worker deploy:staging",
    "deploy:npm-proxy:production": "pnpm --filter @lemonize/npm-proxy-worker deploy:production",
    "deploy:web": "pnpm --filter @lemonize/web deploy",
    "cli:link": "pnpm --filter @lemonize/cli build && pnpm --filter @lemonize/cli link --global",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "vitest": "4.1.10",
    "tar": "^7.4.3",
    "@types/tar": "^6.1.13"
  }
}

# ------------------------------------------------------------------
# Lemonize environment example. Copy to .env for local tooling and to
# infrastructure/wrangler/.dev.vars for the Worker. NEVER commit real values.
# ------------------------------------------------------------------

# Public registry base URL used by the CLI and web app
LEMONIZE_REGISTRY=http://127.0.0.1:8787
REGISTRY_BASE_URL=http://127.0.0.1:8787
WEB_BASE_URL=http://127.0.0.1:3000

# Feature flags (Worker vars)
ALLOW_PUBLIC_PUBLISH=true
ALLOW_PRIVATE_PACKAGES=false
MAX_TARBALL_SIZE_BYTES=10485760   # 10 MiB public-beta publisher cap
MAX_UNPACKED_SIZE_BYTES=104857600 # 100 MB
MAX_PACKAGE_FILES=2000
MAX_GLOBAL_ARTIFACT_BYTES=1073741824
RATE_LIMIT_READS_PER_MINUTE=600
RATE_LIMIT_WRITES_PER_MINUTE=60

# CORS allowlist (comma separated). Use exact origins in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Web app public config
NEXT_PUBLIC_REGISTRY_URL=http://127.0.0.1:8787

# Publishing policy (Worker vars). Publisher eligibility comes from a linked
# GitHub account; administrator authority uses immutable Clerk subject IDs.
ADMIN_CLERK_IDS=
REGISTRY_MODE=public
PRODUCTION_WRITE_APPROVED=

# ------------------------------------------------------------------
# Deployment automation. Keep tokens/keys empty here and store real
# values only in protected GitHub environment secrets.
# ------------------------------------------------------------------
DEPLOY_ENV=staging

# Cloudflare credentials (secrets) and isolated environment resources (vars)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
WORKER_NAME=lemonize-registry-staging
CF_KV_NAMESPACE_ID=
CF_R2_BUCKET=lemonize-artifacts-staging
CLOUDFLARE_ROUTE_PATTERN=staging-registry.example.com
NPM_PROXY_BASE_URL=https://npm-staging.example.com

# Vercel CLI credentials/project linkage
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Appwrite CLI project linkage and native backup policy
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=lemonize-staging-2026
APPWRITE_DATABASE_ID=registry
APPWRITE_QUARANTINE_BUCKET_ID=quarantine
APPWRITE_SCANNER_FUNCTION_ID=artifact-scanner
# Local Worker runtime key. Protected CI uses the separate keys below.
APPWRITE_API_KEY=
APPWRITE_DEPLOY_API_KEY=
APPWRITE_RUNTIME_API_KEY=
APPWRITE_BACKUP_API_KEY=
APPWRITE_BACKUP_POLICY_ID=lemonize-12h
APPWRITE_BACKUP_RETENTION_DAYS=7
APPWRITE_BACKUP_SCHEDULE="17 */12 * * *"

# Clerk verification and Worker-to-scanner signing
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_AUTHORIZED_PARTIES=https://staging.example.com
CLERK_SECRET_KEY=
SCANNER_SHARED_SECRET=

# Smoke-test targets populated from the deployment output/provider domains
REGISTRY_SMOKE_URL=https://staging-registry.example.com
WEB_SMOKE_URL=https://staging.example.com
NPM_PROXY_SMOKE_URL=https://npm-staging.example.com
